{
  "name": "playwright-network-chaos-mcp",
  "version": "0.2.0",
  "description": "MCP server that gives AI agents dynamic network chaos control over Playwright browser sessions",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "playwright-network-chaos-mcp": "./dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "server.json"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc && chmod +x dist/index.js",
    "prepack": "chmod +x dist/index.js",
    "lint": "eslint src",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "keywords": [
    "playwright",
    "mcp",
    "chaos",
    "network",
    "resilience",
    "testing",
    "sdet"
  ],
  "author": "vola-trebla",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "playwright": "^1.52.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "**/*.{ts,mjs,json,md}": [
      "prettier --write"
    ],
    "src/**/*.ts": [
      "eslint --fix"
    ]
  },
  "mcpName": "io.github.vola-trebla/playwright-network-chaos-mcp",
  "repository": {
    "type": "git",
    "url": "https://github.com/vola-trebla/playwright-network-chaos-mcp.git"
  }
}
